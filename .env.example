# App
PORT=3000
NODE_ENV=production

# M.O.M record retention (temporary archive)
MOM_RECORD_RETENTION_DAYS=30
MOM_RECORD_MAX_COUNT=60
APP_HOST=127.0.0.1
APP_BASE_URL=http://localhost:3000
MOM_GENERATED_BY=ETPL_AI M.O.M System

# Zoho / OAuth
ZOHO_USE_MOCK=false
ZOHO_ENRICH_PROJECT_STAGE=true
ZOHO_BASE_URL=https://projectsapi.zoho.in/restapi
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.in
ZOHO_PORTAL_ID=your_portal_id_here
ZOHO_ACCESS_TOKEN=
ZOHO_REFRESH_TOKEN=your_refresh_token_here
ZOHO_CLIENT_ID=your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here
ORG_USER_EMAIL_DOMAIN=elegrow.com
# Optional override if your org uses a different endpoint
ZOHO_PROJECTS_ENDPOINT=

# SMTP Email (optional: only if sending mail through SMTP)
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_password_here
SMTP_FROM=mom-app@example.com

# Microsoft Graph Draft Integration (recommended for reliable Outlook draft creation)
MS_GRAPH_ENABLED=false
MS_GRAPH_AUTHORITY_HOST=https://login.microsoftonline.com
MS_GRAPH_TENANT_ID=your_tenant_id_here
MS_GRAPH_CLIENT_ID=your_graph_app_client_id_here
MS_GRAPH_CLIENT_SECRET=your_graph_app_client_secret_here
MS_GRAPH_MAILBOX_USER=your_mailbox_user@elegrow.com
MS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
MS_GRAPH_SCOPE=https://graph.microsoft.com/.default

# Google Gemini M.O.M Assistant
GEMINI_ENABLED=true
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_MAX_UPLOAD_BYTES=15728640
